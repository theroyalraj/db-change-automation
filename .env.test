# ═══════════════════════════════════════════════════════════
# Test environment — safe defaults for local testing
# ═══════════════════════════════════════════════════════════

JIRA_BASE_URL=https://test.atlassian.net
JIRA_EMAIL=test@test.com
JIRA_API_TOKEN=test-token
JIRA_PROJECT_KEY=TEST
JIRA_ISSUE_TYPE=Task
JIRA_AUTH_TYPE=cloud
JIRA_DBA_APPROVER_FIELD=customfield_10001
JIRA_DONE_TRANSITION_ID=31
JIRA_IN_REVIEW_TRANSITION_ID=21
JIRA_FAILED_TRANSITION_ID=41

GITHUB_TOKEN=ghp_test_token
GITHUB_REPO=test-org/test-repo
GITHUB_REQUIRED_REVIEWERS=dba-team

ENVIRONMENTS=preprod,prod
UAT_ENABLED=false
PROD_REQUIRES_MANUAL_APPROVAL=false

PREPROD_DB_TYPE=mysql
PREPROD_DB_HOST=localhost
PREPROD_DB_PORT=3309
PREPROD_DB_NAME=appdb
PREPROD_DB_USERNAME=liquibase_user
PREPROD_DB_PASSWORD=secure_password
PREPROD_DB_SSL=false
PREPROD_DB_MYSQL_VERSION=5.5

PROD_DB_TYPE=mysql
PROD_DB_HOST=localhost
PROD_DB_PORT=3307
PROD_DB_NAME=appdb
PROD_DB_USERNAME=liquibase_user
PROD_DB_PASSWORD=secure_password
PROD_DB_SSL=false
PROD_DB_MYSQL_VERSION=5.7

DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3307
DB_NAME=appdb
DB_USERNAME=liquibase_user
DB_PASSWORD=secure_password
DB_SSL=false

TEST_DB_HOST=localhost
TEST_DB_PORT=3307
TEST_DB_NAME=appdb
TEST_DB_USERNAME=liquibase_user
TEST_DB_PASSWORD=secure_password

BYTEBASE_URL=http://localhost:8080
BYTEBASE_SERVICE_ACCOUNT=test@bytebase.com
BYTEBASE_SERVICE_KEY=test-key
BYTEBASE_PROJECT_ID=test-project
BYTEBASE_ENVIRONMENT=test

LIQUIBASE_CHANGELOG_PATH=changelogs/master.xml
LIQUIBASE_CONTEXTS=test
LIQUIBASE_LABELS=

NOTIFICATION_CHANNELS=
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_SECURE=false
EMAIL_FROM=test@test.com
EMAIL_USERNAME=test
EMAIL_PASSWORD=test
EMAIL_DBA_RECIPIENTS=dba@test.com
EMAIL_DEV_NOTIFY=false

WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACtest
TWILIO_AUTH_TOKEN=test-token
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000
WHATSAPP_DBA_NUMBERS=whatsapp:+10000000001
WHATSAPP_NOTIFY_ON=all

SCHEDULING_ENABLED=false
SCHEDULE_TIMEZONE=UTC

DML_APPROVAL_REQUIRED=false
DML_JIRA_ISSUE_TYPE=Sub-task
DML_AUTO_APPROVE_ROW_LIMIT=100
DML_ALLOWED_ENVIRONMENTS=preprod
DML_PROD_ENABLED=false

REQUIRE_APPROVAL_BEFORE_DEPLOY=false
AUTO_ROLLBACK_ON_FAILURE=true
NOTIFY_SLACK_ON_FAILURE=false
SLACK_WEBHOOK_URL=

COMPLIANCE_MODE=NONE
AUDIT_LOG_RETENTION_DAYS=30
ENFORCE_SEPARATION_OF_DUTIES=false
REQUIRE_ROLLBACK_SCRIPT=false
