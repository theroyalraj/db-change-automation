# ═══════════════════════════════════════════════════════════
# DB CHANGE AUTOMATION — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── JIRA ────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-service-account@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=DBCHANGE
JIRA_ISSUE_TYPE=Task
JIRA_AUTH_TYPE=cloud                     # cloud | server
JIRA_DBA_APPROVER_FIELD=customfield_10001
JIRA_DONE_TRANSITION_ID=31
JIRA_IN_REVIEW_TRANSITION_ID=21
JIRA_FAILED_TRANSITION_ID=41

# ─── GITHUB ──────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxx
GITHUB_REPO=org/repo-name
GITHUB_REQUIRED_REVIEWERS=dba-team

# ─── MULTI-ENVIRONMENT CONFIG ───────────────────────────
# Ordered promotion chain — changes deploy through these sequentially
ENVIRONMENTS=preprod,uat,prod
UAT_ENABLED=true                         # Set false to skip UAT entirely
PROD_REQUIRES_MANUAL_APPROVAL=true       # Gate before prod deployment

# ─── DATABASE (PREPROD) ─────────────────────────────────
# NOTE: MySQL 5.5 is NOT supported by Liquibase or Bytebase.
# The adapter auto-detects the version and falls back to direct SQL
# execution via mysql2, tracking changes in DB_CHANGE_TRACKER table.
PREPROD_DB_TYPE=mysql
PREPROD_DB_HOST=preprod-db.company.com
PREPROD_DB_PORT=3306
PREPROD_DB_NAME=appdb
PREPROD_DB_USERNAME=liquibase_user
PREPROD_DB_PASSWORD=secure_password
PREPROD_DB_SSL=false
PREPROD_DB_MYSQL_VERSION=5.5             # Actual MySQL version (5.5.37)

# ─── DATABASE (UAT) ─────────────────────────────────────
UAT_DB_TYPE=mysql
UAT_DB_HOST=uat-db.company.com
UAT_DB_PORT=3306
UAT_DB_NAME=appdb
UAT_DB_USERNAME=liquibase_user
UAT_DB_PASSWORD=secure_password
UAT_DB_SSL=true
UAT_DB_MYSQL_VERSION=5.7

# ─── DATABASE (PROD) ────────────────────────────────────
PROD_DB_TYPE=mysql
PROD_DB_HOST=prod-db.company.com
PROD_DB_PORT=3306
PROD_DB_NAME=appdb
PROD_DB_USERNAME=liquibase_user
PROD_DB_PASSWORD=secure_password
PROD_DB_SSL=true
PROD_DB_MYSQL_VERSION=5.7                # Actual MySQL version (5.7.28)

# ─── DATABASE (PRIMARY — fallback if per-env not set) ───
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=appdb
DB_USERNAME=liquibase_user
DB_PASSWORD=secure_password
DB_SSL=true

# ─── DATABASE (TEST) ────────────────────────────────────
TEST_DB_HOST=localhost
TEST_DB_PORT=3307
TEST_DB_NAME=testdb
TEST_DB_USERNAME=test_user
TEST_DB_PASSWORD=test_password

# ─── BYTEBASE ───────────────────────────────────────────
BYTEBASE_URL=http://localhost:8080
BYTEBASE_SERVICE_ACCOUNT=service@bytebase.com
BYTEBASE_SERVICE_KEY=your-bytebase-service-key
BYTEBASE_PROJECT_ID=db-automation
BYTEBASE_ENVIRONMENT=prod

# ─── LIQUIBASE ───────────────────────────────────────────
LIQUIBASE_CHANGELOG_PATH=changelogs/master.xml
LIQUIBASE_CONTEXTS=prod
LIQUIBASE_LABELS=

# ─── NOTIFICATIONS ──────────────────────────────────────
# Comma-separated list of channels. Empty = disabled.
NOTIFICATION_CHANNELS=email,whatsapp

# Email (SMTP / SendGrid)
EMAIL_SMTP_HOST=smtp.company.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=true
EMAIL_FROM=dbchanges@company.com
EMAIL_USERNAME=service-account
EMAIL_PASSWORD=smtp-password
EMAIL_DBA_RECIPIENTS=dba@company.com,dba2@company.com
EMAIL_DEV_NOTIFY=true                    # Notify changeset author on status changes

# WhatsApp (Twilio)
WHATSAPP_PROVIDER=twilio                 # twilio | meta
TWILIO_ACCOUNT_SID=ACxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_DBA_NUMBERS=whatsapp:+919876543210,whatsapp:+919876543211
# Events that trigger WhatsApp: failure | prod_deploy | approval_needed | all
WHATSAPP_NOTIFY_ON=failure,prod_deploy,approval_needed

# ─── SCHEDULING ─────────────────────────────────────────
SCHEDULING_ENABLED=true
SCHEDULE_TIMEZONE=Asia/Kolkata           # IANA timezone for scheduled jobs

# ─── DML CONFIG ─────────────────────────────────────────
DML_APPROVAL_REQUIRED=true               # Require approval for INSERT/UPDATE/DELETE
DML_JIRA_ISSUE_TYPE=Sub-task             # Separate Jira ticket type for DML
DML_AUTO_APPROVE_ROW_LIMIT=0             # 0 = always require approval; >0 = auto-approve if rows < limit
DML_ALLOWED_ENVIRONMENTS=preprod,uat     # Prod DML blocked by default
DML_PROD_ENABLED=false                   # Explicit flag to allow prod DML

# ─── PIPELINE BEHAVIOUR ─────────────────────────────────
REQUIRE_APPROVAL_BEFORE_DEPLOY=true
AUTO_ROLLBACK_ON_FAILURE=true
NOTIFY_SLACK_ON_FAILURE=false
SLACK_WEBHOOK_URL=

# ─── COMPLIANCE ─────────────────────────────────────────
# SOX | PCI_DSS | HIPAA | GDPR | NONE
COMPLIANCE_MODE=SOX
AUDIT_LOG_RETENTION_DAYS=2555            # 7 years for SOX
ENFORCE_SEPARATION_OF_DUTIES=true
REQUIRE_ROLLBACK_SCRIPT=true
