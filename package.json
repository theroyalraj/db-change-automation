{
  "name": "db-change-automation",
  "version": "1.0.0",
  "description": "Production-ready, fully automated Database Change Management system with multi-environment promotion, notifications, scheduling, and separate DDL/DML flows",
  "main": "scripts/core/changeset-parser.js",
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --selectProjects unit",
    "test:integration": "jest --config jest.config.js --selectProjects integration",
    "test:e2e": "jest --config jest.config.js --selectProjects e2e",
    "test:coverage": "jest --config jest.config.js --coverage",
    "validate:env": "node scripts/utils/env-validator.js",
    "lint": "echo 'Add ESLint config as needed'",
    "pipeline:pr-open": "node scripts/pipeline/on-pr-open.js",
    "pipeline:pr-merge": "node scripts/pipeline/on-pr-merge.js",
    "pipeline:dml-pr": "node scripts/pipeline/on-dml-pr.js",
    "pipeline:schedule": "node scripts/pipeline/on-schedule.js",
    "pipeline:failure": "node scripts/pipeline/on-failure.js"
  },
  "keywords": [
    "database",
    "migration",
    "liquibase",
    "bytebase",
    "jira",
    "automation",
    "devops",
    "ci-cd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.0",
    "twilio": "^5.4.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xml2js": "^0.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "nock": "^14.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
